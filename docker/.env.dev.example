# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=poster_db
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=30m
DB_CONN_MAX_IDLE_TIME=5m
DB_SLOW_QUERY_THRESHOLD=250ms

# Redis
REDIS_ADDR=redis:6379
## If your Redis instance requires a password, set it here. Otherwise, leave it blank. Both situations are supported.
REDIS_PASSWORD=
REDIS_DB=0

# Optional Traefik gateway in Docker dev mode
TRAEFIK_HTTP_PORT=8088
TRAEFIK_HTTPS_PORT=8443
TRAEFIK_LOG_LEVEL=INFO
TRAEFIK_RATE_LIMIT_AVERAGE=100
TRAEFIK_RATE_LIMIT_PERIOD=1s
TRAEFIK_RATE_LIMIT_BURST=200
TRAEFIK_RATE_LIMIT_REDIS_ENDPOINTS=redis:6379
TRAEFIK_RATE_LIMIT_REDIS_DB=0

# Observability stack ports
PROMETHEUS_PORT=9090
LOKI_PORT=3100
ALLOY_PORT=12345
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# AI Service
AI_SERVICE_URL=http://ai-service:8000
LLM_PROVIDER_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o
LLM_PROVIDER_KEY=your_llm_provider_key_here
LLM_REQUEST_TIMEOUT_SECONDS=90
LLM_MAX_RETRIES=2
LLM_STREAM_CHUNK_TIMEOUT_SECONDS=30

# App
PORT=8080
APP_ENV=development
JWT_SECRET=replace-with-a-strong-random-secret
BACKEND_API_BASE_URL=http://backend:8080
# Standalone backend role. Docker Compose overrides this per service.
BACKEND_PROCESS_ROLE=all
BACKEND_REQUIRE_REDIS=false
BACKEND_API_REPLICAS=1
APP_RATE_LIMIT_ENABLED=true
APP_RATE_LIMIT_KEY_PREFIX=mpp:ratelimit
# Generate with script/cookie/gen_cookie_encryption_key.sh or .ps1.
COOKIE_ENCRYPTION_KEY=replace-with-exactly-32-byte-secret
# Optional. Set to the browser-worker service URL, for example http://browser-worker:8081.
# Docker Compose defaults blank values to http://browser-worker:8081. Leave blank outside Compose to use the backend mock worker.
BROWSER_WORKER_URL=
BROWSER_RUNTIME_IMAGE=mpp-browser-runtime
BROWSER_RUNTIME_NETWORK=mpp-browser-runtime
BROWSER_RUNTIME_BIND_IP=127.0.0.1
BROWSER_RUNTIME_HOST=127.0.0.1
BROWSER_SESSION_USER_CONCURRENCY_LIMIT=2
BROWSER_SESSION_TENANT_CONCURRENCY_LIMIT=10
BROWSER_WORKER_POOL_SIZE=4

# Local development only
ENABLE_MOCK_LOGIN=true
ENABLE_DEV_SEED=true

# Optional browser extension dev profile
EXTENSION_DEV_PORT=3010

# X OAuth 2.0 app
X_OAUTH2_CLIENT_ID=your_x_oauth2_client_id_here
X_OAUTH2_CLIENT_SECRET=your_x_oauth2_client_secret_here
X_OAUTH2_REDIRECT_URL=http://127.0.0.1:3000/api/user/dashboard/settings/x/oauth2/callback

# Email Service (SMTP)
# For QQ Mail: Host=smtp.qq.com, Port=587, Password=your_authorization_code
SMTP_HOST=
SMTP_PORT=587
SMTP_FROM=
SMTP_PASSWORD=

# Public frontend origin. Also passed into the frontend image build for SEO
# canonical, Open Graph, sitemap, and structured-data URLs.
FRONTEND_BASE_URL=http://127.0.0.1:3000
